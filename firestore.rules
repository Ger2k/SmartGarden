rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function hasOnlyPlantKeys() {
      return request.resource.data.keys().hasOnly([
        'userId',
        'plantTypeId',
        'perenualSpeciesId',
        'nickname',
        'plantingDate',
        'wateringMode',
        'wateringFrequencySpringDays',
        'wateringFrequencySummerDays',
        'wateringFrequencyAutumnDays',
        'wateringFrequencyWinterDays',
        'rainAlertLevel',
        'healthStatus',
        'healthScore',
        'createdAt',
        'updatedAt'
      ]);
    }

    function validPlant(uid) {
      return hasOnlyPlantKeys()
        && request.resource.data.userId == uid
        && request.resource.data.plantTypeId is string
        && (
          !('perenualSpeciesId' in request.resource.data)
          || request.resource.data.perenualSpeciesId == null
          || request.resource.data.perenualSpeciesId is number
        )
        && request.resource.data.plantingDate is timestamp
        && (
          !('wateringMode' in request.resource.data)
          || request.resource.data.wateringMode in ['auto', 'manual']
        )
        && (
          !('wateringFrequencySpringDays' in request.resource.data)
          || request.resource.data.wateringFrequencySpringDays == null
          || request.resource.data.wateringFrequencySpringDays is number
        )
        && (
          !('wateringFrequencySummerDays' in request.resource.data)
          || request.resource.data.wateringFrequencySummerDays == null
          || request.resource.data.wateringFrequencySummerDays is number
        )
        && (
          !('wateringFrequencyAutumnDays' in request.resource.data)
          || request.resource.data.wateringFrequencyAutumnDays == null
          || request.resource.data.wateringFrequencyAutumnDays is number
        )
        && (
          !('wateringFrequencyWinterDays' in request.resource.data)
          || request.resource.data.wateringFrequencyWinterDays == null
          || request.resource.data.wateringFrequencyWinterDays is number
        )
        && (
          !('rainAlertLevel' in request.resource.data)
          || request.resource.data.rainAlertLevel in ['low', 'medium', 'high']
        )
        && request.resource.data.healthStatus in ['Healthy', 'Needs attention', 'At risk']
        && request.resource.data.healthScore is number;
    }

    function hasOnlyTaskKeys() {
      return request.resource.data.keys().hasOnly([
        'userId',
        'plantId',
        'carePlanId',
        'type',
        'dueDate',
        'priority',
        'weatherGuidance',
        'weatherReason',
        'status',
        'completedAt',
        'createdAt',
        'updatedAt'
      ]);
    }

    function validTask(uid) {
      return hasOnlyTaskKeys()
        && request.resource.data.userId == uid
        && request.resource.data.type in ['watering', 'harvest', 'monitoring']
        && (
          !('priority' in request.resource.data)
          || request.resource.data.priority in ['low', 'medium', 'high']
        )
        && (
          !('weatherGuidance' in request.resource.data)
          || request.resource.data.weatherGuidance in ['none', 'suggest_postpone', 'skip_recommended']
        )
        && (
          !('weatherReason' in request.resource.data)
          || request.resource.data.weatherReason == null
          || request.resource.data.weatherReason is string
        )
        && request.resource.data.status in ['pending', 'completed', 'skipped']
        && request.resource.data.dueDate is timestamp
        && (
          request.resource.data.status != 'completed'
          || request.resource.data.completedAt is timestamp
        );
    }

    match /plantTypes/{plantTypeId} {
      allow read: if true;
      allow write: if false;
    }

    match /users/{uid} {
      allow read, write: if isOwner(uid);

      match /plants/{plantId} {
        allow read: if isOwner(uid);
        allow create, update: if isOwner(uid) && validPlant(uid);
        allow delete: if isOwner(uid);
      }

      match /tasks/{taskId} {
        allow read: if isOwner(uid);
        allow create, update: if isOwner(uid) && validTask(uid);
        allow delete: if isOwner(uid);
      }

      match /carePlans/{planId} {
        allow read, create, update, delete: if isOwner(uid);
      }
    }
  }
}
